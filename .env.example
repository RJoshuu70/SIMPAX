# =============================================================
# SIMPAX - Environment Variables Template
# =============================================================
# Salin file ini menjadi ".env" lalu isi dengan nilai asli.
# JANGAN PERNAH commit file ".env" (sudah masuk .gitignore).
# =============================================================

# --- PostgreSQL ---
POSTGRES_DB=simpax
POSTGRES_USER=simpax_admin
POSTGRES_PASSWORD=ganti_dengan_password_kuat
POSTGRES_PORT=5432

# --- JHipster Backend (Spring Boot) ---
SPRING_PROFILES_ACTIVE=dev
BACKEND_PORT=8080
JHIPSTER_SECURITY_AUTHENTICATION_JWT_BASE64_SECRET=ganti_dengan_secret_base64_minimal_256bit

# --- Apache APISIX ---
APISIX_ADMIN_KEY=ganti_dengan_admin_key_apisix
APISIX_HTTP_PORT=9080
APISIX_ADMIN_PORT=9180

# --- etcd (Config Store untuk APISIX) ---
ETCD_PORT=2379

# --- Apache Syncope ---
SYNCOPE_ADMIN_PASSWORD=ganti_dengan_password_syncope_admin
SYNCOPE_PORT=8081

# --- Apache Fortress ---
FORTRESS_ADMIN_PASSWORD=ganti_dengan_password_fortress_admin
FORTRESS_LDAP_PORT=389

# --- JWT Policy (sesuai PRD Bab 11.3) ---
JWT_ALGORITHM=RS256
JWT_EXPIRY_MINUTES=15
